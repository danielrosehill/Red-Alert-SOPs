// Readiness Posture — Elderly / Mobility Limited
#import "checklist.typ": checklist

#checklist(
  title: "Readiness — Elderly / Mobility Limited",
  subtitle: "Red Alert SOP — For buildings WITHOUT a Mamad / Mamak",
  sections: (
    (
      name: "Protected Space Setup",
      items: (
        (item: "Protected space pre-selected and practised", detail: "Identified from every room; practised reaching it"),
        (item: "Bed or sofa repositioned against inner wall (if needed)", detail: "Below window line, not facing door — for those who cannot move quickly"),
        (item: "No shelves or heavy objects above bed/sofa", detail: ""),
        (item: "Routes to protected space cleared of obstacles", detail: "Rugs, plant pots, chairs, cables — anything that could trip or block a wheelchair"),
        (item: "Grab rails or support available along the route", detail: "Wall-mounted rails, furniture positioned for support, walker accessible"),
      ),
    ),
    (
      name: "Equipment & Supplies",
      items: (
        (item: "Wheelchair / walker / mobility aid within reach", detail: "Charged if electric; not folded away in a closet"),
        (item: "Phone within arm's reach at all times", detail: "Charged, volume ON, Red Alert app active"),
        (item: "Medications in protected space or go bag", detail: "Especially time-critical: insulin, inhalers, heart medication"),
        (item: "Chair positioned in stairwell (if that's your protected space)", detail: "For sitting during the 10-minute wait"),
        (item: "Torch within reach — not just in go bag", detail: "Especially important if mobility is limited in the dark"),
      ),
    ),
    (
      name: "Support Network",
      items: (
        (item: "Buddy system arranged with a neighbour", detail: "Someone who will check on you or help you move when the siren sounds"),
        (item: "Neighbour has a key or knows how to reach you", detail: ""),
        (item: "Emergency contacts saved and easily accessible", detail: "Family, neighbour buddy, building committee"),
        (item: "Family members know the plan", detail: "Who helps whom, who grabs what, designated roles during a siren"),
      ),
    ),
  ),
  footer-note: "DISCLAIMER: This is NOT an official government resource. Use at your own risk. Based on Home Front Command (Pikud HaOref) guidelines. For official guidance visit oref.org.il.",
)
