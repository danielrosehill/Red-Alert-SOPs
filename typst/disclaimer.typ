// Shared disclaimer footer for all SOP documents

#let disclaimer = [
  #line(length: 100%, stroke: 0.5pt + rgb("#cccccc"))
  #v(0.15em)
  #text(size: 6.5pt, fill: rgb("#888888"))[
    *DISCLAIMER:* This is NOT an official government resource. Use at your own risk. Based on Israel Home Front Command (Pikud HaOref) guidelines but not endorsed or verified by any official body. For official guidance visit #link("https://www.oref.org.il")[oref.org.il]. Verify time-to-shelter for your specific area. Always wait 10 minutes in the protected space after an alert.
  ]
]
