// Nighttime Readiness Posture Checklist
#import "checklist.typ": checklist

#checklist(
  title: "Nighttime Readiness Posture",
  subtitle: "Red Alert SOP — For buildings WITHOUT a Mamad / Mamak",
  sections: (
    (
      name: "Before Bed Setup",
      items: (
        (item: "News / situation scan completed", detail: "Check current threat level — assess if it is safe to sleep at home tonight"),
        (item: "Phone charging, volume ON, location services ON", detail: "Red Alert app active; Do Not Disturb OFF or alerts whitelisted"),
        (item: "Clothes laid out by bed", detail: "Full outfit ready to throw on in seconds — shirt, pants, underwear"),
        (item: "Closed-toe shoes positioned by bed", detail: "Ready to step into immediately; not across the room"),
        (item: "Torch / flashlight within arm's reach", detail: "On nightstand or bedside — not buried in go bag"),
        (item: "Glasses positioned by bed (if needed)", detail: "Same spot every night — grab without thinking"),
        (item: "Keys accessible and in known location", detail: "By bed or on hook by front door — not buried in a coat pocket"),
      ),
    ),
    (
      name: "Go Bag & Exit Route",
      items: (
        (item: "Baby carrier by front door and ready to grab", detail: "Wrap or structured carrier — you may need both hands free"),
        (item: "Go bag packed and positioned by front door", detail: ""),
        (item: "Infant supplies in go bag", detail: "Pacifier, bottle/formula, nappies, wipes, muslin/blanket"),
        (item: "Medications in go bag (if taking)", detail: ""),
        (item: "Power bank on charge and ready to grab", detail: "Near go bag or by front door"),
        (item: "Hallway and exit route clear of obstructions", detail: "Can navigate in the dark without tripping"),
        (item: "Front door can be opened quickly", detail: "Not double-locked; key at hand if needed"),
      ),
    ),
    (
      name: "Sleep Conditions",
      items: (
        (item: "No earplugs — hearing must be clear", detail: "You must be able to hear the siren and phone alert"),
        (item: "Protected space priority order — understood", detail: "Mamad > Shelter > Inner stairwell > Inner room  (see decision flowchart)"),
        (item: "Route to nearest shelter — known and walkable in the dark", detail: "Have you walked it at night? Know alternate if primary is locked?"),
      ),
    ),
  ),
  footer-note: "DISCLAIMER: This is NOT an official government resource. Use at your own risk. Based on Home Front Command (Pikud HaOref) guidelines. For official guidance visit oref.org.il.",
)
