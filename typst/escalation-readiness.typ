// Escalation Readiness — Upping Your Posture
#import "checklist.typ": checklist

#checklist(
  title: "Escalation Readiness",
  subtitle: "When the security situation deteriorates — 72-hour preparation",
  sections: (
    (
      name: "Water & Food (72 Hours Minimum)",
      items: (
        (item: "Water — 3L per person per day × 3 days", detail: "Sealed bottles; stored in protected space or by go bag; replace every 3 months"),
        (item: "Water for infants — extra for formula prep", detail: "Bottled water suitable for babies; enough for 72 hours"),
        (item: "Non-perishable food for 72 hours", detail: "Canned goods, crackers, dried fruit, energy bars — no cooking required"),
        (item: "Baby food / formula / snacks for 72 hours", detail: "Pre-measured formula; pouches; age-appropriate snacks"),
        (item: "Pet food for 72 hours (if applicable)", detail: ""),
        (item: "Manual can opener + disposable plates/cutlery", detail: ""),
      ),
    ),
    (
      name: "Power & Communications",
      items: (
        (item: "Power banks — fully charged", detail: "Enough to charge all phones for 72 hours"),
        (item: "Battery-powered or hand-crank radio", detail: "For updates if internet/cell goes down; test batteries"),
        (item: "Spare batteries (AA, AAA, torch)", detail: "For torch, radio, and any medical devices"),
        (item: "Car — at least half a tank of fuel", detail: "Fill up before stations get crowded"),
        (item: "Cash on hand", detail: "ATMs and card readers may go offline"),
      ),
    ),
    (
      name: "Medical & Documents",
      items: (
        (item: "Medications — 72-hour supply in go bag", detail: "Prescriptions, inhalers, insulin, EpiPens + printed prescriptions"),
        (item: "First aid kit — stocked and checked", detail: "Bandages, antiseptic, painkillers, personal medical supplies"),
        (item: "Copies of essential documents in sealed bag", detail: "ID, passport, licence, insurance, medical records, baby vaccination booklet"),
      ),
    ),
    (
      name: "Household & Comfort",
      items: (
        (item: "Torches checked, batteries fresh", detail: "One per room + one in go bag"),
        (item: "Blankets or sleeping bags", detail: "For sheltering; nights can be cold"),
        (item: "Change of clothes for each family member", detail: "In go bag or protected space; include warm layer"),
        (item: "Hygiene: toilet paper, wet wipes, nappies, sanitiser, garbage bags", detail: ""),
        (item: "Activities for children", detail: "Colouring books, games, stationery — shelter waits are long for kids"),
        (item: "Fire extinguisher + smoke detector — functional", detail: ""),
        (item: "Gas supply checked", detail: "Private: spare tank full. Shared building: tank > half full"),
      ),
    ),
    (
      name: "Readiness Actions",
      items: (
        (item: "All household members briefed on the plan", detail: "Shelters, roles, what to grab"),
        (item: "Shelter check completed", detail: "Nearest shelters verified, routes walked, access confirmed"),
        (item: "Go bag fully packed and by the door", detail: "Ready for sheltering-in-place and evacuation"),
        (item: "Emergency contacts list — printed and in go bag", detail: "Family, neighbours, doctor, insurance"),
        (item: "Daytime + nighttime postures activated", detail: "Switch to full readiness — see posture checklists"),
      ),
    ),
  ),
  footer-note: "DISCLAIMER: This is NOT an official government resource. Use at your own risk. Based on Home Front Command (Pikud HaOref) guidelines. For official guidance visit oref.org.il.",
)
