// Escalation Readiness — Upping Your Posture
#import "checklist.typ": checklist

#checklist(
  title: "Escalation Readiness",
  subtitle: "When the security situation deteriorates — 72-hour preparation",
  sop-id: "SOP-3",
  sections: (
    (
      name: "Water & Food (72 Hours Minimum)",
      items: (
        (item: [*Water* — 3L per person per day × 3 days], response: "CHECKED", note: "Sealed bottles; stored in protected space or by go bag; replace every 3 months"),
        (item: [*Water for infants* — extra for formula prep], response: "CHECKED", note: "Bottled water suitable for babies; enough for 72 hours"),
        (item: [*Non-perishable food* for 72 hours], response: "CHECKED", note: "Canned goods, crackers, dried fruit, energy bars — no cooking required"),
        (item: [*Baby food* / formula / snacks for 72 hours], response: "CHECKED", note: "Pre-measured formula; pouches; age-appropriate snacks"),
        (item: [*Pet food* for 72 hours (if applicable)], response: "CHECKED", note: ""),
        (item: [Manual *can opener* + disposable plates/cutlery], response: "CHECKED", note: ""),
      ),
    ),
    (
      name: "Power & Communications",
      items: (
        (item: [*Power banks* fully charged], response: "CHECKED", note: "Enough to charge all phones for 72 hours"),
        (item: [Battery-powered or hand-crank *radio*], response: "CHECKED", note: "For updates if internet/cell goes down; test batteries"),
        (item: [Spare *batteries* (AA, AAA, torch)], response: "CHECKED", note: "For torch, radio, and any medical devices"),
        (item: [*Car* — at least half a tank of fuel], response: "CHECKED", note: "Fill up before stations get crowded"),
        (item: [*Cash* on hand], response: "CHECKED", note: "ATMs and card readers may go offline"),
      ),
    ),
    (
      name: "Medical & Documents",
      items: (
        (item: [*Medications* — 72-hour supply in go bag], response: "CHECKED", note: "Prescriptions, inhalers, insulin, EpiPens + printed prescriptions"),
        (item: [*First aid kit* stocked], response: "CHECKED", note: "Bandages, antiseptic, painkillers, personal medical supplies"),
        (item: [Copies of essential *documents* in sealed bag], response: "CHECKED", note: "ID, passport, licence, insurance, medical records, baby vaccination booklet"),
      ),
    ),
    (
      name: "Household & Comfort",
      items: (
        (item: [*Torches* checked, batteries fresh], response: "CHECKED", note: "One per room + one in go bag"),
        (item: [*Blankets* or sleeping bags], response: "CHECKED", note: "For sheltering; nights can be cold"),
        (item: [*Change of clothes* for each family member], response: "CHECKED", note: "In go bag or protected space; include warm layer"),
        (item: [*Hygiene*: toilet paper, wipes, nappies, sanitiser], response: "CHECKED", note: ""),
        (item: [*Activities* for children], response: "CHECKED", note: "Colouring books, games, stationery — shelter waits are long for kids"),
        (item: [*Fire extinguisher* + smoke detector], response: "CHECKED", note: ""),
        (item: [*Gas supply*], response: "CHECKED", note: "Private: spare tank full. Shared building: tank > half full"),
      ),
    ),
    (
      name: "Readiness Actions",
      items: (
        (item: [All *household members* briefed on plan], response: "CHECKED", note: "Shelters, roles, what to grab"),
        (item: [*Shelter check* completed], response: "CHECKED", note: "Nearest shelters verified, routes walked, access confirmed"),
        (item: [*Go bag* fully packed and by the door], response: "CHECKED", note: "Ready for sheltering-in-place and evacuation"),
        (item: [*Emergency contacts* list printed], response: "CHECKED", note: "Family, neighbours, doctor, insurance"),
        (item: [*Daytime + nighttime postures* activated], response: "CHECKED", note: "Switch to full readiness — see posture checklists"),
      ),
    ),
  ),
)
